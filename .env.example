# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Turso (cloud libSQL) — pokud nastaveno, DB se synchronizuje do Turso.
# Necháte-li prázdné, aplikace používá lokální SQLite soubor v data/realitka.db.
TURSO_DATABASE_URL=libsql://<your-db>-<your-org>.turso.io
TURSO_AUTH_TOKEN=

# Resend (transakční email) — doporučeno pro produkci.
# Necháte-li prázdné, zkusí se nodemailer (GMAIL_USER/GMAIL_APP_PASSWORD);
# pokud chybí oboje, email se zobrazí jen jako draft v chatu.
RESEND_API_KEY=
RESEND_FROM="Realitka <onboarding@resend.dev>"

# Gmail SMTP (fallback pro lokální vývoj)
GMAIL_USER=
GMAIL_APP_PASSWORD=
